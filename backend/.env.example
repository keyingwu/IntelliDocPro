# IntelliDocPro engine credentials. Replace REPLACE_ME with real values; for engines
# you don't use, delete the whole section or leave it empty (keeping the placeholder
# makes /health wrongly report that engine as configured).
# This file is in .gitignore and will not be committed.

# ---- Claude ----
ANTHROPIC_API_KEY=REPLACE_ME
# Optional, defaults to claude-opus-4-8
# INTELLIDOCPRO_CLAUDE_MODEL=claude-opus-4-8

# ---- OpenAI (native) ----
OPENAI_API_KEY=REPLACE_ME
# Optional, defaults to gpt-5.6-luna (cost); alternatives: gpt-5.6-sol (accuracy) / gpt-5.6-terra (balanced)
# INTELLIDOCPRO_OPENAI_MODEL=gpt-5.6-luna

# ---- Azure OpenAI ----
# Endpoint looks like https://<resource-name>.openai.azure.com
AZURE_OPENAI_ENDPOINT=REPLACE_ME
AZURE_OPENAI_API_KEY=REPLACE_ME
# The deployment name you created on Azure (also serves as the model name)
AZURE_OPENAI_DEPLOYMENT=REPLACE_ME
