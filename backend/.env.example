# IntelliDocPro 引擎凭据。把 REPLACE_ME 换成真实值；不用的引擎整段删掉或留空即可
# （留着 placeholder 会让 /health 误报该引擎"已配置"）。
# 此文件已在 .gitignore 中，不会被提交。

# ---- Claude ----
ANTHROPIC_API_KEY=REPLACE_ME
# 可选，默认 claude-opus-4-8
# INTELLIDOCPRO_CLAUDE_MODEL=claude-opus-4-8

# ---- OpenAI 原生 ----
OPENAI_API_KEY=REPLACE_ME
# 可选，默认 gpt-5.6-terra；可换 gpt-5.6-sol（精度）/ gpt-5.6-luna（成本）
# INTELLIDOCPRO_OPENAI_MODEL=gpt-5.6-terra

# ---- Azure OpenAI ----
# endpoint 形如 https://<资源名>.openai.azure.com
AZURE_OPENAI_ENDPOINT=REPLACE_ME
AZURE_OPENAI_API_KEY=REPLACE_ME
# 你在 Azure 上创建的 deployment 名（同时充当模型名）
AZURE_OPENAI_DEPLOYMENT=REPLACE_ME
